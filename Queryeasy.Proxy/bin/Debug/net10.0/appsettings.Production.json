{
  "Proxy": {
    "ListenHost": "127.0.0.1",
    "ListenPort": 11433,
    "TargetHost": "127.0.0.1",
    "TargetPort": 1433,
    "ConnectTimeoutSeconds": 10,
    "IdleTimeoutMinutes": 30,
    "BufferSizeBytes": 81920,
    "LogLevel": "Info",
    "Mode": "DryRun",
    "LogPayloadPreview": false,
